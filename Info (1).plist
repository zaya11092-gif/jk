<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ============================================================ -->
    <!--  Bundle identity                                              -->
    <!-- ============================================================ -->

    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>

    <key>CFBundleExecutable</key>
    <string>IntelXeDriver</string>

    <key>CFBundleIdentifier</key>
    <string>com.intelxe.driver.IntelXeDriver</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>Intel Xe Framebuffer Driver</string>

    <key>CFBundlePackageType</key>
    <string>KEXT</string>

    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>

    <key>CFBundleVersion</key>
    <string>0.1.0</string>

    <!-- ============================================================ -->
    <!--  IOKit driver personality — match & load rules                -->
    <!-- ============================================================ -->

    <key>IOKitPersonalities</key>
    <dict>
        <key>IntelIrisXeFramebuffer</key>
        <dict>

            <!-- The C++ class that will be instantiated on a match -->
            <key>IOClass</key>
            <string>IntelXeDriver</string>

            <!-- Must match the CFBundleIdentifier above            -->
            <key>CFBundleIdentifier</key>
            <string>com.intelxe.driver.IntelXeDriver</string>

            <!-- Match against any IOPCIDevice instance             -->
            <key>IOProviderClass</key>
            <string>IOPCIDevice</string>

            <!--
                Primary match string:
                Upper 16 bits = PCI Vendor ID   (0x8086 = Intel)
                Lower 16 bits = PCI Device ID   (0x46A6 = Alder Lake-P IGP)
                Concatenated as a single 32-bit hex value.
            -->
            <key>IOPCIPrimaryMatch</key>
            <string>0x808646A6</string>

            <!--
                IOMatchCategory forces IOKit to treat this match in
                the IOFramebuffer category so that the display-stack
                matching path (rather than generic IOKit) is used.
            -->
            <key>IOMatchCategory</key>
            <string>IOFramebuffer</string>

            <!--
                Probe score — 1000 is high enough to preempt Apple's
                built-in Intel framebuffer for this specific device ID
                during Phase 1 testing.  Lower this if you need to
                coexist with the stock driver.
            -->
            <key>IOProbeScore</key>
            <integer>1000</integer>

        </dict>
    </dict>

    <!-- ============================================================ -->
    <!--  Required loadable KEXT dependencies                          -->
    <!-- ============================================================ -->

    <key>OSBundleLibraries</key>
    <dict>
        <key>com.apple.iokit.IOPCIFamily</key>
        <string>2.9</string>

        <key>com.apple.iokit.IOGraphicsFamily</key>
        <string>2.4.1</string>
    </dict>

    <!--
        OSBundleRequired = "Console" signals that this KEXT provides
        console (display) services and should be loaded early enough
        for the login-window / graphical console to appear.
    -->
    <key>OSBundleRequired</key>
    <string>Console</string>

</dict>
</plist>